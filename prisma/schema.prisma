generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  admin
  student
  parent
  school
}

enum SignupStatus {
  pending_confirmation
  confirmed
}

model User {
  id             String   @id @default(cuid())
  moodleUserId   Int      @unique
  username       String
  email          String?
  firstName      String?
  lastName       String?
  profileImage   String?
  role           UserRole @default(student)
  isSuspended    Boolean  @default(false)
  lastPasswordResetAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastLoginAt    DateTime?

  enrollments    UserCourseEnrollment[]

  @@index([role])
}

model PendingSignup {
  id          String       @id @default(cuid())
  username    String       @unique
  email       String
  firstName   String?
  lastName    String?
  role        UserRole
  status      SignupStatus @default(pending_confirmation)
  moodleUserId Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  confirmedAt DateTime?

  @@index([status])
}

model ParentChild {
  id        String   @id @default(cuid())
  parentId  Int
  childId   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([parentId, childId])
  @@index([parentId])
  @@index([childId])
}

model RegistrationRole {
  id        String   @id @default(cuid())
  username  String   @unique
  role      UserRole
  createdAt DateTime @default(now())

  @@index([username])
}

model CourseCatalog {
  id             String   @id @default(cuid())
  moodleCourseId Int      @unique
  shortname      String
  fullname       String
  summary        String?
  categoryId     Int?
  categoryName   String?
  isVisible      Boolean  @default(true)
  price          Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  enrollments    UserCourseEnrollment[]

  @@index([categoryId])
  @@index([isVisible])
}

model UserCourseEnrollment {
  id              String        @id @default(cuid())
  userId          String
  courseCatalogId String
  progress        Int           @default(0)
  isActive        Boolean       @default(true)
  enrolledAt      DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id])
  courseCatalog   CourseCatalog @relation(fields: [courseCatalogId], references: [id])

  @@unique([userId, courseCatalogId])
  @@index([userId])
  @@index([courseCatalogId])
}

model AdminActivityLog {
  id            String   @id @default(cuid())
  adminUserId   Int
  targetUserId  String?
  action        String
  details       Json?
  createdAt     DateTime @default(now())

  @@index([adminUserId])
  @@index([targetUserId])
  @@index([action])
}

model RegistrationCountries {
  id        Int      @id @default(autoincrement())
  username  String   
  country   String   
  code      String?   
  name      String?   
  createdAt DateTime @default(now()) @map("created_at") // <-- Updated this line

  @@map("registration_countries")
}
model Orders {
  id          Int      @id @default(autoincrement())
  username    String
  userId      Int?     @map("user_id")
  status      String   @default("pending")
  totalAmount Float?   @map("total_amount") // <-- Add this final column right here
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("orders")
}

model Inquiries {
  id        Int      @id @default(autoincrement())
  username  String
  userId    Int?     @map("user_id") // <-- Add this line
  message   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("inquiries")
}