generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String                 @id @default(cuid())
  moodleUserId        Int                    @unique
  username            String
  email               String?
  firstName           String?
  lastName            String?
  profileImage        String?
  role                UserRole               @default(student)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  lastLoginAt         DateTime?
  isSuspended         Boolean                @default(false)
  lastPasswordResetAt DateTime?
  enrollments         UserCourseEnrollment[]

  @@index([role])
  @@map("users")
}

model PendingSignup {
  id           String       @id @default(cuid())
  username     String       @unique
  email        String
  firstName    String?
  lastName     String?
  role         UserRole
  status       SignupStatus @default(pending_confirmation)
  moodleUserId Int?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  confirmedAt  DateTime?

  @@index([status])
  @@map("pending_signups")
}

model ParentChild {
  id        String   @id @default(cuid())
  parentId  Int
  childId   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([parentId, childId])
  @@index([parentId])
  @@index([childId])
  @@map("parent_child")
}

model RegistrationRole {
  id        String   @id @default(cuid())
  username  String   @unique
  role      UserRole
  createdAt DateTime @default(now())

  @@index([username])
  @@map("registration_roles")
}

model CourseCatalog {
  id             String                 @id @default(cuid())
  moodleCourseId Int                    @unique
  shortname      String
  fullname       String
  summary        String?
  categoryId     Int?
  categoryName   String?
  isVisible      Boolean                @default(true)
  price          Float                  @default(0)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  lastSyncedAt   DateTime?              @map("last_synced_at")
  enrollments    UserCourseEnrollment[]

  @@index([categoryId])
  @@index([isVisible])
  @@map("course_catalog")
}

model UserCourseEnrollment {
  id              String        @id @default(cuid())
  progress        Int           @default(0)
  isActive        Boolean       @default(true)
  enrolledAt      DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  courseCatalogId String        @map("course_catalog_id")
  userId          String        @map("user_id")
  courseCatalog   CourseCatalog @relation(fields: [courseCatalogId], references: [id])
  user            User          @relation(fields: [userId], references: [id])

  @@unique([userId, courseCatalogId])
  @@index([userId])
  @@index([courseCatalogId])
  @@map("enrollments")
}

model AdminActivityLog {
  id           String   @id @default(cuid())
  targetUserId String?
  details      Json?
  createdAt    DateTime @default(now())
  adminUserId  Int
  action       String

  @@index([adminUserId])
  @@index([targetUserId])
  @@index([action])
  @@map("admin_activity_logs")
}

model RegistrationCountries {
  id        Int      @id @default(autoincrement())
  code      String?
  name      String?
  username  String
  country   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("registration_countries")
}

model Inquiries {
  id              Int      @id @default(autoincrement())
  message         String?
  createdAt       DateTime @default(now()) @map("created_at")
  userId          Int?     @map("user_id")
  type            String   @default("contact")
  name            String
  email           String
  phone           String?
  role            String?
  gradeLevel      String?  @map("grade_level")
  subjectInterest String?  @map("subject_interest")
  learningMode    String?  @map("learning_mode")
  status          String?  @default("new")

  @@map("inquiries")
}

model Orders {
  id                  Int      @id @default(autoincrement())
  totalAmount         Float    @map("total_amount")
  status              String   @default("pending")
  createdAt           DateTime @default(now()) @map("created_at")
  userId              String?  @map("user_id")
  paymentStatus       String?  @default("pending") @map("payment_status")
  paymentProvider     String?  @map("payment_provider")
  paymentRef          String?  @map("payment_ref")
  invoiceNumber       String?  @map("invoice_number")
  paidAmount          Int?     @map("paid_amount")
  remainingAmount     Int?     @map("remaining_amount")
  allowPartialPayment Boolean? @map("allow_partial_payment")
  refundStatus        String?  @map("refund_status")
  paymentNotes Json?   @map("payment_notes")
  items               OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        Int    @id @default(autoincrement())
  orderId   Int    @map("order_id")
  programId Int    @map("program_id")
  price     Int
  order     Orders @relation(fields: [orderId], references: [id])

  @@map("order_items")
}

model PendingPayments {
  orderRef        String    @id @map("order_ref")
  userId          String    @map("user_id")
  items           Json
  totalAmount     Int       @map("total_amount")
  amountToPay     Int?      @map("amount_to_pay")
  scholarshipCode String?   @map("scholarship_code")
  tracker         String?
  orderId         Int?      @map("order_id")
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("pending_payments")
}

model ScholarshipCodes {
  code              String    @id
  moodleUserId      Int       @map("moodle_user_id")
  email             String
  name              String
  country           String
  concessionPercent Int       @map("concession_percent")
  region            String
  expiresAt         DateTime  @map("expires_at") @db.Timestamp(6)
  used              Boolean   @default(false)
  usedAt            DateTime? @map("used_at") @db.Timestamp(6)
  usedByUserId      String?   @map("used_by_user_id")
  createdAt         DateTime? @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("scholarship_codes")
}

model RegisteredCountries {
  moodleUserId Int       @id @map("moodle_user_id")
  country      String
  updatedAt    DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  @@map("registered_countries")
}

model DashboardNotificationReads {
  id             Int       @id @default(autoincrement())
  userId         Int       @map("user_id")
  notificationId Int       @map("notification_id")
  readAt         DateTime? @default(now()) @map("read_at") @db.Timestamp(6)

  @@unique([userId, notificationId])
  @@map("dashboard_notification_reads")
}

model SchoolLicenses {
  id           String    @id
  schoolUserId Int       @map("school_user_id")
  courseId     Int       @map("course_id")
  courseName   String    @map("course_name")
  totalSeats   Int       @map("total_seats")
  orderId      Int       @map("order_id")
  purchaseDate DateTime? @default(now()) @map("purchase_date") @db.Timestamp(6)
  expiresAt    DateTime? @map("expires_at") @db.Timestamp(6)

  @@index([schoolUserId])
  @@map("school_licenses")
}

model SchoolRosterStudents {
  id             Int       @id @default(autoincrement())
  schoolUserId   Int       @map("school_user_id")
  studentId      Int       @map("student_id")
  studentEmail   String    @map("student_email")
  studentName    String    @map("student_name")
  uploadedAt     DateTime? @default(now()) @map("uploaded_at") @db.Timestamp(6)
  sourceUploadId String    @map("source_upload_id")

  @@unique([schoolUserId, studentId])
  @@index([schoolUserId])
  @@map("school_roster_students")
}

model SchoolStudentUploads {
  id                String    @id
  schoolUserId      Int       @map("school_user_id")
  filename          String
  totalStudents     Int       @map("total_students")
  processedStudents Int       @map("processed_students")
  failedStudents    Int       @map("failed_students")
  status            String
  errors            Json?     @default("[]")
  uploadedAt        DateTime? @default(now()) @map("uploaded_at") @db.Timestamp(6)

  @@index([schoolUserId])
  @@map("school_student_uploads")
}

model SchoolSeatAssignments {
  id           String    @id
  schoolUserId Int       @map("school_user_id")
  licenseId    String    @map("license_id")
  studentId    Int       @map("student_id")
  studentEmail String    @map("student_email")
  studentName  String    @map("student_name")
  assignedAt   DateTime? @default(now()) @map("assigned_at") @db.Timestamp(6)
  isAtRisk     Boolean   @default(false) @map("is_at_risk")
  riskReasons  Json?     @map("risk_reasons")
  lastRiskCheckAt DateTime? @map("last_risk_check_at") @db.Timestamp(6)

  @@unique([licenseId, studentId])
  @@index([schoolUserId])
  @@index([schoolUserId, isAtRisk])
  @@map("school_seat_assignments")
}

model EdumeContactSubmissions {
  id               Int      @id @default(autoincrement())
  consultationType String   @map("consultation_type")
  name             String
  email            String
  country          String?
  subject          String?
  message          String?
  schoolName       String?  @map("school_name")
  studentCount     String?  @map("student_count")
  device           String?
  problemType      String?  @map("problem_type")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("edume_contact_submissions")
}

enum UserRole {
  admin
  student
  parent
  school
}

enum SignupStatus {
  pending_confirmation
  confirmed
}

model EdumeDiagnosticSessions {
  sessionToken   String    @id @map("session_token")
  moodleUserId   Int?      @map("moodle_user_id")
  ipAddress      String?   @map("ip_address")
  diagnosticType Int       @map("diagnostic_type")
  subject        String?
  grade          String?
  variant        String?
  paid           Boolean   @default(false)
  status         String
  resultJson     Json?     @map("result_json")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("edume_diagnostic_sessions")
}

model EdumeGuestDiagnostics {
  id             Int       @id @default(autoincrement())
  sessionToken   String    @map("session_token")
  ipAddress      String    @map("ip_address")
  subject        String?
  diagnosticType String    @map("diagnostic_type")
  moodleUserId   Int?      @map("moodle_user_id")
  completed      Boolean   @default(false)
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("edume_guest_diagnostics")
}

model EdumeDiagnosticAnswers {
  id           Int      @id @default(autoincrement())
  sessionToken String   @map("session_token")
  questionId   String   @map("question_id")
  answer       Json
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("edume_diagnostic_answers")
}

model EdumeDiagnosticAccountFlags {
  id                 Int      @id @default(autoincrement())
  moodleUserId       Int      @unique @map("moodle_user_id")
  freeDiagnosticUsed Boolean  @default(false) @map("free_diagnostic_used")
  teacherT1Attempts  Int      @default(0) @map("teacher_t1_attempts")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("edume_diagnostic_account_flags")
}

// ============================================================
// 4.21 — Background Job Queue (DB-backed, no Redis required)
// ============================================================
model BackgroundJob {
  id          String    @id @default(cuid())
  type        String    // e.g. ENROLL_USER, SEND_EMAIL, MOODLE_SYNC, PAYMENT_VERIFY
  payload     Json
  status      String    @default("pending") // pending | running | done | failed
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)         @map("max_attempts")
  runAt       DateTime  @default(now())     @map("run_at")
  lockedAt    DateTime?                     @map("locked_at")
  lockedBy    String?                       @map("locked_by")
  doneAt      DateTime?                     @map("done_at")
  errorMsg    String?                       @map("error_msg")
  createdAt   DateTime  @default(now())     @map("created_at")
  updatedAt   DateTime  @updatedAt          @map("updated_at")

  @@index([status, runAt])
  @@index([type])
  @@map("background_jobs")
}

// 4.20 — Dead Letter Queue for exhausted jobs
model DeadLetterJob {
  id          String   @id @default(cuid())
  type        String
  payload     Json
  attempts    Int
  lastError   String   @map("last_error")
  originalId  String   @map("original_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([type])
  @@map("dead_letter_jobs")
}

model SchoolFormSubmission {
  id               String    @id
  schoolUserId     Int       @map("school_user_id")
  teacherUserId    Int?      @map("teacher_user_id")
  reportMonth      String    @map("report_month") @db.VarChar(7)
  status           String    @db.VarChar(16)
  payload          Json
  reviewedByUserId Int?      @map("reviewed_by_user_id")
  reviewNotes      String?   @map("review_notes")
  reviewedAt       DateTime? @map("reviewed_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([schoolUserId])
  @@index([status])
  @@map("school_form_submissions")
}

model SchoolMonthlySnapshot {
  id            String   @id
  schoolUserId  Int      @map("school_user_id")
  snapshotMonth String   @map("snapshot_month") @db.VarChar(7)
  snapshotData  Json     @map("snapshot_data")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([schoolUserId, snapshotMonth])
  @@index([schoolUserId])
  @@map("school_monthly_snapshots")
}

model SchoolReportActivityLog {
  id           String   @id
  schoolUserId Int      @map("school_user_id")
  actorUserId  Int      @map("actor_user_id")
  action       String   @db.VarChar(64)
  details      Json?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([schoolUserId])
  @@index([action])
  @@map("school_report_activity_logs")
}
